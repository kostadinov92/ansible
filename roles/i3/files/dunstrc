[global]
    monitor = 0
    follow = keyboard

    width = (300, 400)
    height = 300
    origin = top-right
    offset = 12x48
    notification_limit = 5

    corner_radius = 6

    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1

    transparency = 10

    padding = 12
    horizontal_padding = 14
    text_icon_padding = 10

    frame_width = 2
    frame_color = "#5E81AC"

    gap_size = 4
    separator_height = 2
    separator_color = auto

    font = MesloLGS Nerd Font 10
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"
    word_wrap = true
    ellipsize = end
    alignment = left
    vertical_alignment = center

    show_age_threshold = 60
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = true

    enable_recursive_icon_lookup = true
    icon_theme = "Adwaita"
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64

    sticky_history = true
    history_length = 30

    browser = /usr/bin/xdg-open
    always_run_script = true
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#2E3440"
    foreground = "#D8DEE9"
    frame_color = "#4C566A"
    highlight = "#5E81AC"
    timeout = 5

[urgency_normal]
    background = "#2E3440"
    foreground = "#ECEFF4"
    frame_color = "#5E81AC"
    highlight = "#88C0D0"
    timeout = 10

[urgency_critical]
    background = "#3B4252"
    foreground = "#ECEFF4"
    frame_color = "#BF616A"
    highlight = "#BF616A"
    timeout = 0
