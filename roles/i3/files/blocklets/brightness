#!/bin/bash
# Scroll to adjust brightness
case $BLOCK_BUTTON in
    4) brightnessctl set +5% >/dev/null 2>&1 ;;
    5) brightnessctl set 5%- >/dev/null 2>&1 ;;
esac

PCT=$(brightnessctl -m 2>/dev/null | cut -d, -f4 | tr -d '%')
[ -z "$PCT" ] && exit 0

ICON=$'\uf0eb'
echo "$ICON ${PCT}%"
echo "$ICON ${PCT}%"
