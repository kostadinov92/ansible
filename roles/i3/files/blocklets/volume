#!/bin/sh
# Left click: toggle mute, right click: open pavucontrol
case $BLOCK_BUTTON in
    1) wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle ;;
    3) pavucontrol & ;;
    4) wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ ;;
    5) wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- ;;
esac

VOL=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null)
PCT=$(echo "$VOL" | awk '{printf "%.0f", $2*100}')
MUTED=$(echo "$VOL" | grep -c MUTED)

if [ "$MUTED" = "1" ]; then
    echo "ó°ťź MUTE"
